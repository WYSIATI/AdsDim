{
  "name": "adsdim",
  "version": "0.1.0",
  "description": "Dim the ads, let real posts shine. Marks ads on the x.com timeline without ever hiding posts.",
  "license": "Apache-2.0",
  "author": "WYSIATI",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:e2e": "ADSDIM_E2E=1 wxt build",
    "zip": "wxt zip",
    "postinstall": "wxt prepare",
    "compile": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitest/coverage-v8": "^3.2.0",
    "@wxt-dev/module-react": "^1.1.3",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.0",
    "wxt": "^0.20.6"
  }
}
